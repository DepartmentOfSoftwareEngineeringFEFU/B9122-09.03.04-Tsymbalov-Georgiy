# СМПА Электросети - Переменные окружения

# Ключ авторизации API
SECRET_KEY=super_secret_key_1234567890_vkr

# Подключение к БД (для локального запуска вне Docker)
# DATABASE_URL=sqlite:///./grid_monitor.db
DATABASE_URL=postgresql://vkr_user:vkr_password@localhost:5432/vkr_db

# Подключение к Redis (для локального запуска вне Docker)
REDIS_URL=redis://localhost:6379/0

# (Опционально) API-ключ OpenWeatherMap для получения реальной погоды
# OPENWEATHER_API_KEY=your_openweathermap_api_key_here
OPENWEATHER_API_KEY=ваш_действующий_ключ_openweathermap
